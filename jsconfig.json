{
    "compilerOptions": {
        "checkJs": true,
        "noImplicitAny": true,
        "strict": true,
        "module": "ESNext",
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "moduleResolution": "bundler"
        
    },
    "include": [
        "types",
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}