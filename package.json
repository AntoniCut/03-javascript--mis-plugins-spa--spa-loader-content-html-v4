{
  "name": "spa-loader-content-html-v4",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "predev": "node predev.js",
    "dev": "concurrently -k -n watch,serve -c yellow,cyan \"pnpm run dev:watch\" \"pnpm run serve:dev\"",
    "dev:watch": "CHOKIDAR_USEPOLLING=true CHOKIDAR_INTERVAL=350 gulp dev",
    "serve:dev": "CHOKIDAR_USEPOLLING=true CHOKIDAR_INTERVAL=350 node server/dev-server.js",
    "stop:dev": "node server/stop-dev-server.js",
    "server": "pnpm run serve:dev",
    "build": "gulp build",
    "preview": "node server/preview-server.js --open",
    "add:ts-nocheck": "cross-env NODE_ENV=development node addTsNoCheck.js",
    "code-highlight": "gulp styles && node generate-markdown-shiki.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/gulp": "^4.0.18",
    "browser-sync": "^3.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "del": "^8.0.1",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-htmlmin": "^5.0.1",
    "gulp-plumber": "^1.2.1",
    "gulp-sass": "^6.0.1",
    "gulp-terser": "^2.1.0",
    "markdown-it": "^14.1.0",
    "markdown-it-shiki": "^0.9.0",
    "sass": "^1.97.3",
    "shiki": "^4.1.0"
  }
}
